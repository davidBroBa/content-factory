    },
    "📦 Agrupar videos": {
      "main": [[{ "node": "🤖 Trend Analyzer (OpenRouter)", "type": "main", "index": 0 }]]
    },
    "🤖 Trend Analyzer (OpenRouter)": {
      "main": [[{ "node": "📋 Parsear tópicos", "type": "main", "index": 0 }]]
    },
