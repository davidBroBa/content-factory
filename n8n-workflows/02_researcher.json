        [{ "node": "💾 Guardar topics", "type": "main", "index": 0 }]
      ]
    },
    "💾 Guardar topics": {
      "main": [[{ "node": "📝 Log éxito", "type": "main", "index": 0 }]]
    }
  },
  "active": true,
  "settings": { "executionOrder": "v1" },
