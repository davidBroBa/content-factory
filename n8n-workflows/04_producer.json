      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1560, 300],
      "id": "http-pexels",
      "name": "🎥 Pexels B-Roll",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Seleccionar el mejor video de Pexels para esta escena\nconst scene = $input.first().json;\nconst pexelsVideos = scene.videos || [];\n\nlet bestVideoUrl = null;\nlet assetSourceId = null;\n\nif (pexelsVideos.length > 0) {\n  const video = pexelsVideos[0];\n  const videoFiles = video.video_files || [];\n  \n  // Priorizar: portrait HD > portrait SD > cualquier cosa\n  let bestFile = videoFiles.find(f => f.width <= f.height && f.quality === 'hd')\n    || videoFiles.find(f => f.width <= f.height)\n    || videoFiles[0];\n  \n  if (bestFile?.link) {\n    bestVideoUrl = bestFile.link;\n    assetSourceId = String(video.id);\n  }\n}\n\n// Fallback: si Pexels no tiene video, usar color sólido (el render worker lo maneja)\nreturn [{\n  json: {\n    scene_number: scene.scene_number || 1,\n    start_s: scene.start_s || 0,\n    end_s: scene.end_s || 7,\n    theme: scene.theme || '',\n    search_query: scene.search_query || '',\n    asset_url: bestVideoUrl,\n    asset_source_id: assetSourceId,\n    has_broll: !!bestVideoUrl\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1800, 300],
      "id": "code-select-broll",
      "name": "🎞️ Seleccionar B-Roll"
    },
