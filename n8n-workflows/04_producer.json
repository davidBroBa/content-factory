    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WHISPER_URL }}/v1/audio/transcriptions",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "parameterType": "formData", "name": "url", "value": "={{ $json.storage_url }}" },
            { "parameterType": "formData", "name": "response_format", "value": "verbose_json" },
            { "parameterType": "formData", "name": "language", "value": "es" },
            { "parameterType": "formData", "name": "timestamp_granularities[]", "value": "word" }
          ]
        },
        "options": { "timeout": 60000 }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1080, 100],
      "id": "http-whisper",
      "name": "🔤 Whisper (subtítulos)",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000,
      "onError": "continueRegularOutput",
      "notes": "Usa Whisper LOCAL — sin costo. Conecta a http://whisper:8000"
    },
    {
      "parameters": {
        "jsCode": "// Parsear segmentos de Whisper para generar subtítulos\nconst whisperData = $input.first().json;\nconst segments = whisperData.segments || [];\nconst words = whisperData.words || [];\n\n// Si hay palabras individuales, usarlas para subtítulos más precisos\nlet subtitleSegments = [];\n\nif (words.length > 0) {\n  // Agrupar palabras en segmentos de 4-5 palabras\n  let currentGroup = [];\n  let groupStart = 0;\n  \n  for (const word of words) {\n    if (currentGroup.length === 0) {\n      groupStart = word.start;\n    }\n    currentGroup.push(word.word);\n    \n    if (currentGroup.length >= 4) {\n      subtitleSegments.push({\n        start: groupStart,\n        end: word.end,\n        text: currentGroup.join(' ').trim()\n      });\n      currentGroup = [];\n    }\n  }\n  \n  // Último grupo\n  if (currentGroup.length > 0) {\n    const lastWord = words[words.length - 1];\n    subtitleSegments.push({\n      start: groupStart,\n      end: lastWord.end,\n      text: currentGroup.join(' ').trim()\n    });\n  }\n} else if (segments.length > 0) {\n  subtitleSegments = segments.map(s => ({\n    start: s.start,\n    end: s.end,\n    text: s.text.trim()\n  }));\n}\n\nreturn [{\n  json: {\n    subtitles: subtitleSegments,\n    total_segments: subtitleSegments.length,\n    duration: whisperData.duration || 0,\n    transcript: whisperData.text || ''\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 100],
      "id": "code-parse-subtitles",
      "name": "📝 Parsear subtítulos"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENROUTER_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"openai/gpt-4o-mini\",\n  \"temperature\": 0.2,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un editor de video experto. Crea un timeline de escenas para B-roll basado en la transcripción. Responde SOLO JSON válido con formato: {\\\"scenes\\\": [{\\\"scene_number\\\": int, \\\"start_s\\\": float, \\\"end_s\\\": float, \\\"theme\\\": string, \\\"search_query\\\": string en INGLÉS para Pexels, máx 4 palabras}]}. Las escenas deben cubrir TODO el audio sin huecos. Cada escena 4-8 segundos.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ 'Transcripción completa (duración ' + $('🔤 Whisper (subtítulos)').item.json.duration + 's):\\\\n' + $('🔤 Whisper (subtítulos)').item.json.text + '\\\\n\\\\nCrea el timeline de B-roll para un Short vertical sobre: ' + $('📋 Obtener guion pendiente').item.json.topic }}\"\n    }\n  ]\n}",
        "options": { "timeout": 30000 }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1080, 300],
      "id": "http-scene-generator",
      "name": "🎬 Scene Generator (OpenRouter)",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Parsear escenas del LLM\nconst response = $input.first().json;\nlet scenes = [];\n\ntry {\n  const content = response.choices?.[0]?.message?.content || '{}';\n  const parsed = JSON.parse(content);\n  scenes = parsed.scenes || [];\n} catch (e) {\n  throw new Error('Error parseando escenas: ' + e.message);\n}\n\nif (scenes.length === 0) {\n  // Fallback: crear escenas uniformes basadas en duración del audio\n  const audioDuration = $('🔤 Whisper (subtítulos)').item.json.duration || 40;\n  const nScenes = Math.ceil(audioDuration / 7); // 7 segundos por escena\n  \n  for (let i = 0; i < nScenes; i++) {\n    scenes.push({\n      scene_number: i + 1,\n      start_s: i * (audioDuration / nScenes),\n      end_s: (i + 1) * (audioDuration / nScenes),\n      theme: 'true crime scene',\n      search_query: ['crime scene investigation', 'detective work', 'court justice', 'police investigation', 'forensic evidence'][i % 5]\n    });\n  }\n}\n\nreturn scenes.map(s => ({ json: s }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 300],
      "id": "code-parse-scenes",
      "name": "📋 Parsear escenas"
    },
    {
      "parameters": {
        "url": "https://api.pexels.com/videos/search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "query", "value": "={{ $json.search_query }}" },
            { "name": "orientation", "value": "portrait" },
            { "name": "per_page", "value": "3" },
            { "name": "size", "value": "medium" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ $env.PEXELS_API_KEY }}" }
          ]
        },
        "options": {
          "timeout": 15000,
          "batching": {
            "batch": {
              "batchSize": 1,
              "batchInterval": 500
            }
          }
        }
