        "query": "SELECT t.id as topic_id, t.topic, t.summary, s.id as script_id, s.full_script, s.title, s.description, s.hashtags FROM factory.topics t JOIN factory.scripts s ON s.topic_id = t.id WHERE t.status = 'pending' AND s.status = 'completed' AND t.produced = FALSE ORDER BY t.trend_score DESC, t.created_at ASC LIMIT 1",
