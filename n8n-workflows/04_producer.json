        "jsonBody": "={\n  \"text\": {{ JSON.stringify($('📋 Obtener guion pendiente').item.json.full_script) }},\n  \"voice\": \"af_heart\",\n  \"script_id\": {{ JSON.stringify($('📋 Obtener guion pendiente').item.json.script_id) }},\n  \"audio_db_id\": {{ JSON.stringify($json.id) }},\n  \"lang\": \"e\"\n}",
