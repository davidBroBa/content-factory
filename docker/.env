# ============================================================
# CONTENT FACTORY — Variables de Entorno
# Copiar a .env y rellenar con valores reales
# NUNCA commitear .env a git
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=factory
POSTGRES_PASSWORD=CAMBIAR_ESTO_password_seguro_2025
POSTGRES_DB=factory

# ---- Redis ----
REDIS_PASSWORD=CAMBIAR_ESTO_redis_seguro_2025

# ---- MinIO ----
MINIO_ROOT_USER=factory_minio
MINIO_ROOT_PASSWORD=CAMBIAR_ESTO_minio_seguro_2025
MINIO_DATA_PATH=/opt/factory/minio

# ---- n8n ----
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_ESTO_n8n_seguro_2025
N8N_ENCRYPTION_KEY=CAMBIAR_ESTO_exactamente_32_chars__

# ---- APIs Externas ----
# OpenRouter (más barato que OpenAI directo)
# Registrarse en: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-CAMBIAR_ESTO

# YouTube Data API v3
# Consola: https://console.cloud.google.com
YOUTUBE_API_KEY=CAMBIAR_ESTO

# Pexels API (gratis con límites generosos)
# https://www.pexels.com/api/
PEXELS_API_KEY=CAMBIAR_ESTO

# ---- Publicación (opcional) ----
# YouTube OAuth (para publicar)
YOUTUBE_CLIENT_ID=CAMBIAR_ESTO
YOUTUBE_CLIENT_SECRET=CAMBIAR_ESTO

# TikTok
TIKTOK_CLIENT_KEY=CAMBIAR_ESTO
TIKTOK_CLIENT_SECRET=CAMBIAR_ESTO

# Instagram / Facebook (Meta API)
META_APP_ID=CAMBIAR_ESTO
META_APP_SECRET=CAMBIAR_ESTO
META_ACCESS_TOKEN=CAMBIAR_ESTO

# Blotato (si usas su servicio de publicación)
BLOTATO_API_KEY=CAMBIAR_ESTO

# ---- Workers ----
MAX_RENDER_WORKERS=2
